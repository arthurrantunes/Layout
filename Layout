<div class="statusbar">
  <span id="status-tool">Ferramenta: Selecionar</span>
  <span id="status-pos">x: 0  y: 0</span>
  <span id="status-size">Canvas: 595 × 842</span>
  <span id="status-sel">Nenhum elemento selecionado</span>
